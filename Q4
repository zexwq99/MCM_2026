def plot_comparison_bars(results_df, optimal, output_path):
    """Figure: Catastrophe Rate Comparison"""
    fig, ax = plt.subplots(figsize=(12, 8))
    
    systems = []
    
    # Current
    current = results_df[(abs(results_df['w'] - 0.5) < 0.03) & (results_df['delta'] == 0)]
    if len(current) > 0:
        c = current.iloc[0]
        systems.append({'name': 'Current System\n(w=0.5, No Save)', 
                       'f3': c['f3_catastrophe']*100, 'color': '#95a5a6',
                       'f1': c['f1_meritocracy'], 'f2': c['f2_excitement']})
    
    # Recommended
    if optimal is not None:
        systems.append({'name': f'RECOMMENDED\n(w={optimal["w"]:.1f}, Save Btm 3)',
                       'f3': optimal['f3_catastrophe']*100, 'color': '#27ae60',
                       'f1': optimal['f1_meritocracy'], 'f2': optimal['f2_excitement']})
    
    # Best Merit
    high_w = results_df[(results_df['w'] >= 0.85) & (results_df['delta'] >= 1)]
    if len(high_w) > 0:
        bm = high_w.loc[high_w['f1_meritocracy'].idxmax()]
        systems.append({'name': 'Best Merit\n(High Judge Weight)',
                       'f3': bm['f3_catastrophe']*100, 'color': '#3498db',
                       'f1': bm['f1_meritocracy'], 'f2': bm['f2_excitement']})
    
    # Best Excitement
    low_w = results_df[results_df['w'] <= 0.25]
    if len(low_w) > 0:
        be = low_w.loc[low_w['f2_excitement'].idxmax()]
        systems.append({'name': 'Best Excitement\n(Low Judge Weight)',
                       'f3': be['f3_catastrophe']*100, 'color': '#e74c3c',
                       'f1': be['f1_meritocracy'], 'f2': be['f2_excitement']})
    
    # Lowest Catastrophe
    lc = results_df.loc[results_df['f3_catastrophe'].idxmin()]
    systems.append({'name': 'Lowest Catastrophe',
                   'f3': lc['f3_catastrophe']*100, 'color': '#9b59b6',
