    ax.axhspan(0, 7, alpha=0.1, color='green')
    
    # Star for recommended
    for i, sys in enumerate(systems):
        if sys['color'] == '#27ae60':
            ax.scatter(i, sys['f3'] + 0.8, marker='*', color='gold', s=300, zorder=10)
    
    ax.set_ylabel('Catastrophe Rate (%)', fontsize=12)
    ax.set_title('Catastrophe Rate Comparison: Current vs. Alternative Systems', 
                fontsize=14, fontweight='bold')
    ax.set_xticks(x)
    ax.set_xticklabels([s['name'] for s in systems], fontsize=10)
    ax.legend(loc='upper right', fontsize=10)
    ax.set_ylim(0, max([s['f3'] for s in systems]) + 3)
