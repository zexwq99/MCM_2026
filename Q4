# Simulation
# =============================================================================

def run_simulation(df):
    results = []
    w_values = np.arange(0, 1.01, 0.05)
    delta_values = [0, 1, 2]
    seasons = df['season'].unique()
    
    np.random.seed(42)
    
    for w in w_values:
        for delta in delta_values:
            f1_list, f2_list, f3_list = [], [], []
            
            for season in seasons:
                season_data = extract_season_data(df, season)
                if len(season_data) < 3:
                    continue
                
                fan_support = estimate_fan_support(season_data)
                
                f1_list.append(calc_meritocracy(season_data, w, delta, fan_support))
                f2_list.append(calc_excitement(season_data, w, delta, fan_support))
                f3_list.append(calc_catastrophe(season_data, w, delta, fan_support))
            
            if f1_list:
                results.append({
                    'w': round(w, 2),
                    'delta': delta,
                    'f1_meritocracy': np.mean(f1_list),
                    'f2_excitement': np.mean(f2_list),
                    'f3_catastrophe': np.mean(f3_list)
                })
    
    return pd.DataFrame(results)

def find_pareto_frontier(results_df):
    pareto = []
    
    for i, row in results_df.iterrows():
        dominated = False
        for j, other in results_df.iterrows():
            if i == j:
                continue
            
            better_eq = (other['f1_meritocracy'] >= row['f1_meritocracy'] and
                        other['f2_excitement'] >= row['f2_excitement'] and
                        other['f3_catastrophe'] <= row['f3_catastrophe'])
            
            strict_better = (other['f1_meritocracy'] > row['f1_meritocracy'] or
                           other['f2_excitement'] > row['f2_excitement'] or
                           other['f3_catastrophe'] < row['f3_catastrophe'])
            
            if better_eq and strict_better:
                dominated = True
                break
        
        if not dominated:
            pareto.append(row)
    
    return pd.DataFrame(pareto)

def find_knee_point(pareto_df):
    if len(pareto_df) == 0:
        return None
    
    f1_min, f1_max = pareto_df['f1_meritocracy'].min(), pareto_df['f1_meritocracy'].max()
    f2_min, f2_max = pareto_df['f2_excitement'].min(), pareto_df['f2_excitement'].max()
    f3_min, f3_max = pareto_df['f3_catastrophe'].min(), pareto_df['f3_catastrophe'].max()
    
    min_dist = float('inf')
    best = None
    
    for _, row in pareto_df.iterrows():
        f1_norm = (row['f1_meritocracy'] - f1_min) / (f1_max - f1_min + 1e-9)
        f2_norm = (row['f2_excitement'] - f2_min) / (f2_max - f2_min + 1e-9)
        f3_norm = (row['f3_catastrophe'] - f3_min) / (f3_max - f3_min + 1e-9)
        
        dist = np.sqrt((1 - f1_norm)**2 + (1 - f2_norm)**2 + f3_norm**2)
        
        if dist < min_dist:
            min_dist = dist
            best = row
    
    return best

